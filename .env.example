# ============================================================
# 程序管理系统 - 环境变量配置模板
# 复制此文件为 .env 并修改所有值
# ============================================================

# ---- 应用 ----
APP_ENV=development
SERVER_PORT=8080
AUTO_MIGRATE=true
FRONTEND_DIST=../frontend/dist

# ---- 数据库 ----
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=crane_user
DB_PASSWORD=zlzk.12345678
DB_NAME=crane_system

# Docker Compose 专用: 暴露到宿主机的 MySQL 端口
# DB_PORT_EXPOSE=3306
# MYSQL_ROOT_PASSWORD=your-strong-db-password

# ---- 认证 ----
# JWT 密钥（至少 32 个字符，生产环境请使用随机生成的强密钥）
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
# 默认密码（至少 8 个字符，用于重置用户密码）
DEFAULT_PASSWORD=admin123456

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- 存储 ----
UPLOADS_DIR=./uploads
BACKUPS_DIR=./backups

# ---- 前端 Docker 专用 ----
# FRONTEND_PORT=80
